#!/usr/bin/env bash
# Configures Nginx to add a custom X-Served-By header set to this server's hostname

set -e

# Install Nginx if not already installed
apt-get update -y
apt-get install -y nginx

# Add a custom header config file with this server's hostname
echo "add_header X-Served-By \"$(hostname)\";" > /etc/nginx/conf.d/custom_header.conf

# Restart Nginx to apply changes
service nginx restart
